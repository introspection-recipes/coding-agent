{
  "name": "@introspection-recipes/coding-agent",
  "version": "0.1.1",
  "description": "A git-backed Pi recipe for managed Introspection runtimes.",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "managed-agent",
    "recipe"
  ],
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "check": "recipes check . --profile ci",
    "check:json": "recipes check . --profile ci --json",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@introspection-ai/pi-recipes": "^0.6.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "agents": [
      "./agents/*.yaml"
    ]
  }
}
